# ─── DATABASE (Postgres Container) ─────────────────────────────────────────────
# Credentials used by the PostgreSQL container to initialize the DB, and by the
# backend API container to run migrations and queries.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=lookimmo

# Prisma connection URL (Note 'db' matches the docker-compose service name)
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public&connection_limit=10"

# ─── API SERVER ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# JWT Authentication Secrets (Must change to long, random strings in production!)
JWT_SECRET="generate-a-secure-jwt-secret-here"
JWT_REFRESH_SECRET="generate-a-secure-jwt-refresh-secret-here"
JWT_EXPIRES_IN="7d"

# ─── CORS & DOMAIN CONFIGURATION ──────────────────────────────────────────────
# Replace with your actual domain name in production (no trailing slash)
FRONTEND_URL="https://look-immo.tn"
BACKEND_URL="https://look-immo.tn"

# ─── OPTIONAL FEATURES ────────────────────────────────────────────────────────
# S3-compatible Object Storage (Optional - fallback to local filesystem if blank)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_URL=

# Error Monitoring (Sentry DSNs - optional)
SENTRY_DSN=
VITE_SENTRY_DSN=

# Structured Logging Level
LOG_LEVEL=info
