# Database
DATABASE_URL="postgresql://postgres:123456@localhost:5432/lookimmo?schema=public&connection_limit=5&pgbouncer=true"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:3000"

# Exchange Rates (optional — leave blank to use free open.er-api.com, no key required)
# For higher quotas, get a key from https://www.exchangerate-api.com and set it here
EXCHANGE_RATE_API_KEY=
