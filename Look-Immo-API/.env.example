# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lookimmo?schema=public&connection_limit=5&pgbouncer=true"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lookimmo?schema=public&connection_limit=5&pgbouncer=true"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000

NODE_ENV=production
# CORS — set to your actual frontend domain in production
FRONTEND_URL="https://look-immo.tn"

# S3-compatible Object Storage (Optional - fallback to local filesystem if not set)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_URL=

# Error Monitoring (Sentry)
# SENTRY_DSN for backend logging
SENTRY_DSN=
# VITE_SENTRY_DSN for frontend logging (defined in frontend environment)
VITE_SENTRY_DSN=
