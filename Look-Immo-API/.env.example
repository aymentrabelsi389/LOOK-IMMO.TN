# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lookimmo?schema=public&connection_limit=5&pgbouncer=true"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000

NODE_ENV=production
# CORS — set to your actual frontend domain in production
FRONTEND_URL="https://look-immo.tn"

# Public URL of the backend server — used by seoInjector to resolve relative
# image paths to absolute URLs for og:image (WhatsApp, Facebook previews).
# In production this is typically the same domain when behind Nginx reverse proxy.
BACKEND_URL="https://look-immo.tn"

# S3-compatible Object Storage (Optional - fallback to local filesystem if not set)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_URL=

# ─── Automated Database Backups ───────────────────────────────────────────────
# Backups use the same S3_* credentials above — no separate account needed.
# The backup script uploads to S3_BUCKET under BACKUP_S3_PREFIX/.
# Run manually: npm run backup
# Scheduled:    PM2 cron in ecosystem.config.js (every Sunday 02:00 UTC)

# Sub-folder inside S3_BUCKET where backup dumps are stored
BACKUP_S3_PREFIX=db-backups/

# Human-readable database name used in the backup filename
BACKUP_DB_NAME=lookimmo

# How many days to keep backups before pruning (default: 30)
BACKUP_RETENTION_DAYS=30

# Structured Logging (Winston)
# Controls the minimum log level written to console and log files.
# Options: error | warn | info | http | debug  (default: info in prod, debug in dev)
LOG_LEVEL=info

# Error Monitoring (Sentry)
# SENTRY_DSN for backend logging
SENTRY_DSN=
# VITE_SENTRY_DSN for frontend logging (defined in frontend environment)
VITE_SENTRY_DSN=
