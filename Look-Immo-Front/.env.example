# ─── Frontend Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local and fill in the values

# Backend API base URL
VITE_API_URL=http://localhost:5000

# Error Monitoring (Sentry)
# Get your DSN from https://sentry.io → Project Settings → Client Keys
VITE_SENTRY_DSN=

# ─── Build-time: scripts/generate-sitemap.mjs ───────────────────────────────
# Public site origin used to build absolute URLs in sitemap.xml
SITE_URL=https://look-immo.tn
# Absolute backend API origin reachable at BUILD time (not the /api proxy path)
SITEMAP_API_URL=http://localhost:5000/api

# ─── Runtime: server/prerender-server.mjs ───────────────────────────────────
# Same SITE_URL as above, used for canonical/og:url when injecting bot meta
# Absolute backend API origin reachable from wherever this container runs
PRERENDER_API_URL=http://localhost:5000/api
